{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/file/bot([^/]+)/(.*)",
      "dest": "/api/telegram-proxy.js"
    },
    {
      "src": "/bot([^/]+)/([^/]+)",
      "dest": "/api/telegram-proxy.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ]
}
